@startuml
title Car Rental Service - High Level Component Diagram

left to right direction
skinparam componentStyle rectangle
skinparam shadowing false

package "Frontend (React SPA)" {

    component "React SPA" as ReactSPA
    component "Material UI" as MUI
    component "Axios Client" as Axios

    ReactSPA --> MUI : UI Components
    ReactSPA --> Axios : REST API Calls
}

package "Backend (Spring Boot)" {

    component "Spring Boot Application" as SpringBoot

    component "JWT Security" as JWT

    component "Controllers" as Controllers

    component "Services" as Services

    component "Pricing Strategy\n(Strategy Pattern)" as Pricing

    component "Repositories" as Repositories

    SpringBoot --> JWT
    JWT --> Controllers
    Controllers --> Services
    Services --> Pricing
    Services --> Repositories
}

database "PostgreSQL" as DB

Axios --> SpringBoot : HTTP/JSON
Repositories --> DB : JPA/Hibernate

@enduml